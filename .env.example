# Copy this file to .env and fill in only the values you need.
# Which variables are required depends on your config.yaml choices.

# ── LLM (required — pick one) ─────────────────────────────────────────────
# compose.provider: claude
ANTHROPIC_API_KEY=sk-ant-...

# compose.provider: openai
OPENAI_API_KEY=sk-...

# ── Lead sources ───────────────────────────────────────────────────────────
# Required if sources.github.enabled: true
# Get one at: github.com/settings/tokens (scopes: read:user, user:email)
GITHUB_TOKEN=github_pat_...

# Required if sources.producthunt.enabled: true
# Get one at: producthunt.com/v2/oauth/applications → create app → Developer Token
# Note: the free developer token only exposes the primary maker per product.
# This is a PH API limitation; you'll still get solid leads at lower volume.
PRODUCTHUNT_TOKEN=

# ── Email sending (pick one to match send.provider in config.yaml) ─────────

# send.provider: smtp  (works with any provider — Fastmail, Namecheap, etc.)
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=your-password-or-app-password
SMTP_FROM_EMAIL=you@yourdomain.com   # optional, defaults to SMTP_USER

# send.provider: gmail
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # myaccount.google.com/apppasswords

# send.provider: zohomail  (requires Zoho API Console setup — see README)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_MAIL_REFRESH_TOKEN=
ZOHO_MAIL_ACCOUNT_ID=

# ── CRM (optional — leave blank to skip CRM sync) ─────────────────────────

# crm.provider: hubspot  (free tier works — Settings → Integrations → Private Apps)
HUBSPOT_API_KEY=pat-na1-...

# crm.provider: zohocrm  (requires Zoho API Console setup — see README)
# Reuses ZOHO_CLIENT_ID and ZOHO_CLIENT_SECRET from above
ZOHO_CRM_REFRESH_TOKEN=
