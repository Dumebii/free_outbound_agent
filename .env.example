# ── LLM ───────────────────────────────────────────────────────────────────
# Provide ONE of these (the one matching compose.provider in config.yaml)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Email sending ──────────────────────────────────────────────────────────
# Zoho Mail REST API (send.provider: zohomail)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_MAIL_REFRESH_TOKEN=
ZOHO_MAIL_ACCOUNT_ID=

# Gmail SMTP (send.provider: gmail)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── CRM (optional) ─────────────────────────────────────────────────────────
# Zoho CRM (crm.provider: zohocrm)
ZOHO_CRM_REFRESH_TOKEN=

# ── Lead sources ───────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_...
